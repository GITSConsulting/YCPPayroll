    procedure CreateEmployeeBuffer("@ProjectValue": Code[20]; "@SiteValue": Code[20]; "@SubProgramValue": Code[20]; "@TableNo": Integer; AdvanceHeaderCreate: Record 50000; PurchaseHeaderCreate: Record 38);
    var
        DimValCombo: Record "Dimension Group";
