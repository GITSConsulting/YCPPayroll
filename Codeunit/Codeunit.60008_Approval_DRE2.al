        EmployeeNo2: Code[20];
    begin
        //#ABM007
        GLSetup.GET;
        CLEAR(EmployeeNo);
        CLEAR(EmployeeNo2);

        //Get the project leader
        IF DimValCombo.GET(GLSetup."Global Dimension 1 Code", "@ProjectValue", GLSetup."Global Dimension 2 Code", "@SiteValue") THEN
            EmployeeNo := DimValCombo."Project Leader";

        //Get the program leader
        IF DimValCombo.GET(GLSetup."Global Dimension 1 Code", "@ProjectValue", GLSetup."Shortcut Dimension 6 Code", "@SubProgramValue") THEN
