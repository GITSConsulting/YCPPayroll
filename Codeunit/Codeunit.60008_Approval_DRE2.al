    procedure CopyAdvanceDocument(var AdvanceHeader: Record "Advance Header")
    var
        _PostAdvanceHdr: Record "New Post Advance Header";
        _PostAdvanceLine: Record "New Post Advance Line";
        _AdvanceLine: Record "Advance Line";
        _CopyAdvanceDoc: Page "Copy Advance Document";
        _DocNo: Code[20];
    begin
        AdvanceHeader.TestField("No.");
        _DocNo := AdvanceHeader."No.";
        _PostAdvanceHdr.SetRange("Document Type", AdvanceHeader."Document Type");
        _CopyAdvanceDoc.SetTableView(_PostAdvanceHdr);
        _CopyAdvanceDoc.LookupMode(true);
        if _CopyAdvanceDoc.RunModal = Action::LookupOK then begin
            _CopyAdvanceDoc.GetRecord(_PostAdvanceHdr);
            AdvanceHeader."Purpose of Travel" := _PostAdvanceHdr."Purpose of Travel";
            AdvanceHeader."Starting Date" := _PostAdvanceHdr."Starting Date";
            AdvanceHeader."Ending Date" := _PostAdvanceHdr."Ending Date";
            AdvanceHeader.Justification := _PostAdvanceHdr.Justification;
            AdvanceHeader.Modify();
            _PostAdvanceLine.SetRange("Document Type", _PostAdvanceHdr."Document Type");
            _PostAdvanceLine.SetRange("Document No.", _PostAdvanceHdr."No.");
            if _PostAdvanceLine.FindFirst() then
                repeat
                    _AdvanceLine.Init();
                    _AdvanceLine.TransferFields(_PostAdvanceLine);
                    _AdvanceLine."Document Type" := AdvanceHeader."Document Type";
                    _AdvanceLine."Document No." := AdvanceHeader."No.";
                    _AdvanceLine.Status := _AdvanceLine.Status::Open;
                    _AdvanceLine.Insert();
                until _PostAdvanceLine.Next() = 0;
        end;

    end;

    procedure ImportAttachment(DocumentType: Text; DocumentNo: Code[20])
    var
        _TempBlob: Codeunit "Temp Blob";
        _FileManagement: Codeunit "File Management";
        _InStr: InStream;
        _OutStr: OutStream;
        _LineNo: Integer;
        _FileName: Text;
        _AdvanceAttchEntry: Record "Advance Attachment Entry";
        AdvanceHdr: Record "Advance Header";
    begin
        _FileName := _FileManagement.BLOBImportWithFilter(_TempBlob, ImportTxt, _FileName, StrSubstNo(FileDialogTxt, FilterTxt), FilterTxt);
        if _FileName = '' then
            Error('');

        Evaluate(AdvanceHdr."Document Type", DocumentType);
        AdvanceHdr."No." := DocumentNo;

        _AdvanceAttchEntry.LockTable();
        _AdvanceAttchEntry.SetRange("Document Type", AdvanceHdr."Document Type");
        _AdvanceAttchEntry.SetRange("Document No.", AdvanceHdr."No.");
        if _AdvanceAttchEntry.FindLast() then
            _LineNo += _AdvanceAttchEntry."Line No." + 10000
        else
            _LineNo := 10000;

        _AdvanceAttchEntry.Init();
        _TempBlob.CreateInStream(_InStr);
        _AdvanceAttchEntry.Content.CreateOutStream(_OutStr);
        CopyStream(_OutStr, _InStr);
        _AdvanceAttchEntry."Document Type" := AdvanceHdr."Document Type";
        _AdvanceAttchEntry."Document No." := AdvanceHdr."No.";
        _AdvanceAttchEntry."Line No." := _LineNo;
        _AdvanceAttchEntry."File Name" := _FileName;
        _AdvanceAttchEntry."File Type" := UpperCase(GetFileType(_FileName));
        _AdvanceAttchEntry.Insert();
    end;

    procedure DownloadAttachment(var AdvanceAttchEntry: Record "Advance Attachment Entry")
    var
        _InStr: InStream;
        _tempfilename: text;
    begin

        if AdvanceAttchEntry.Content.HasValue then begin
            AdvanceAttchEntry.CalcFields(Content);
            AdvanceAttchEntry.Content.CreateInStream(_InStr);
            _tempfilename := CreateGuid() + '.' + AdvanceAttchEntry."File Type";
            DownloadFromStream(_InStr, 'Export', '', 'All Files (*.*)|*.*', _tempfilename);
        end else
            Error(ErrorAttachment);
    end;

    local procedure GetFileType(pFilename: Text): Text;
    var
        _FilenamePos: Integer;
    begin
        _FilenamePos := StrLen(pFilename);
        while (pFilename[_FilenamePos] <> '.') or (_FilenamePos < 1) do
            _FilenamePos -= 1;

        if _FilenamePos = 0 then
            exit('');

        exit(CopyStr(pFilename, _FilenamePos + 1, StrLen(pFilename)));
    end;
