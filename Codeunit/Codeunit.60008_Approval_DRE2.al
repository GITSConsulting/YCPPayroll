    procedure GetMultipleSite(DocumentType: Integer; AppProfileIDLineNo: Integer; var HasPrevilege: Boolean; var SiteCode: Code[10]; ApprovalMode: Boolean);
    var
        _Employee: Record 5200;
        _DimValueComb: Record "Dimension Group";
        _Filteran: Text;
        _SiteOption: Text;
        _Selection: Integer;
        _CVBuffer: Record 382 temporary;
        i: Integer;
        _AppProfSetup2: Record "Approval Chain Setup";
        _DimValue2: Record 349;
        _OwnOfficeLoc: Boolean;
    begin
        GLSetup.GET;
        _Employee.SETRANGE("User ID", USERID);
        _Employee.FINDFIRST;
        _DimValueComb.SETRANGE("Dimension 1 Code", GLSetup."Global Dimension 2 Code");
        _DimValueComb.SETFILTER("Dimension 1 Value Code", '<>%1', '');
        _DimValueComb.SETRANGE("Dimension 2 Code", GLSetup."Global Dimension 2 Code");
        _DimValueComb.SETFILTER("Dimension 2 Value Code", '<>%1', '');
        _DimValueComb.SETRANGE(PIC, _Employee."No.");
        IF ApprovalMode THEN BEGIN
            IF _AppProfSetup2.GET(DocumentType, AppProfileIDLineNo) THEN
                IF (_DimValueComb.FINDFIRST) AND (_AppProfSetup2.Verificator) THEN BEGIN
                    _OwnOfficeLoc := FALSE;
                    _Filteran := _DimValueComb."Dimension 1 Value Code";
                    REPEAT
                        _Filteran += '|' + _DimValueComb."Dimension 2 Value Code";
                        IF _Employee."Office Location Code" = _DimValueComb."Dimension 1 Value Code" THEN
                            _OwnOfficeLoc := TRUE;
                    UNTIL _DimValueComb.NEXT = 0;
                    HasPrevilege := _OwnOfficeLoc;
                    _DimValue2.SETRANGE("Dimension Code", GLSetup."Global Dimension 2 Code");
                    _DimValue2.SETFILTER(Code, _Filteran);
                    IF (_DimValue2.FINDFIRST) AND (HasPrevilege) THEN BEGIN
                        REPEAT
                            i += 1;
                            IF _SiteOption = '' THEN
                                _SiteOption := _DimValue2.Name
                            ELSE
                                _SiteOption += ',' + _DimValue2.Name;
                            _CVBuffer.INIT;
                            _CVBuffer."Entry No." := i;
                            _CVBuffer."Global Dimension 2 Code" := _DimValue2.Code;
                            _CVBuffer.INSERT;
                        UNTIL _DimValue2.NEXT = 0;
                        _Selection := STRMENU(_SiteOption, 1);
                        IF _Selection = 0 THEN
                            ERROR('');
                        _CVBuffer.GET(_Selection);
                        SiteCode := _CVBuffer."Global Dimension 2 Code";
                    END;
                END;
        END ELSE
            IF _DimValueComb.FINDFIRST THEN BEGIN
                _OwnOfficeLoc := FALSE;
                _Filteran := _DimValueComb."Dimension 1 Value Code";
                REPEAT
                    _Filteran += '|' + _DimValueComb."Dimension 2 Value Code";
                    IF _Employee."Office Location Code" = _DimValueComb."Dimension 1 Value Code" THEN
                        _OwnOfficeLoc := TRUE;
                UNTIL _DimValueComb.NEXT = 0;
                HasPrevilege := _OwnOfficeLoc;
                _DimValue2.SETRANGE("Dimension Code", GLSetup."Global Dimension 2 Code");
                _DimValue2.SETFILTER(Code, _Filteran);
                IF (_DimValue2.FINDFIRST) AND (HasPrevilege) THEN BEGIN
                    REPEAT
                        i += 1;
                        IF _SiteOption = '' THEN
                            _SiteOption := _DimValue2.Name
                        ELSE
                            _SiteOption += ',' + _DimValue2.Name;
                        _CVBuffer.INIT;
                        _CVBuffer."Entry No." := i;
                        _CVBuffer."Global Dimension 2 Code" := _DimValue2.Code;
                        _CVBuffer.INSERT;
                    UNTIL _DimValue2.NEXT = 0;
                    _Selection := STRMENU(_SiteOption, 1);
                    IF _Selection = 0 THEN
                        SiteCode := _Employee."Office Location Code"
                    ELSE BEGIN
                        _CVBuffer.GET(_Selection);
                        SiteCode := _CVBuffer."Global Dimension 2 Code";
                    END;
                END;
            END;
    end;

    procedure CheckAppliedAmountAccPayable(AppliesToDocNo: Code[20]; AppliedCurrCode: Code[10]; AppliedAmount: Decimal; AppliedAmountLCY: Decimal);
    var
        _VendLedgEntry: Record 25;
        _CurrencyCode: Code[10];
    begin
        IF AppliesToDocNo = '' THEN
            EXIT;

        //_VendLedgEntry.SETRANGE("Document Type",_VendLedgEntry."Document Type"::Invoice);
        _VendLedgEntry.SETRANGE("Document No.", AppliesToDocNo);
        _VendLedgEntry.SETRANGE(Open, TRUE);
        IF _VendLedgEntry.COUNT = 1 THEN BEGIN
            _VendLedgEntry.FINDFIRST;
            _VendLedgEntry.CALCFIELDS("Remaining Amount", "Remaining Amt. (LCY)");
            IF _VendLedgEntry."Currency Code" <> '' THEN
                _CurrencyCode := _VendLedgEntry."Currency Code"
            ELSE
                _CurrencyCode := 'IDR';

            CASE TRUE OF
                (AppliedCurrCode = _VendLedgEntry."Currency Code"):
                    IF AppliedAmount > ABS(_VendLedgEntry."Remaining Amount") THEN
                        ERROR(Text037, _CurrencyCode, ABS(_VendLedgEntry."Remaining Amount"));
                (AppliedCurrCode = '') AND (_VendLedgEntry."Currency Code" <> ''):
                    IF AppliedAmount > ABS(_VendLedgEntry."Remaining Amt. (LCY)") THEN
                        ERROR(Text037, _CurrencyCode, ABS(_VendLedgEntry."Remaining Amt. (LCY)"));
                (AppliedCurrCode <> '') AND (_VendLedgEntry."Currency Code" <> '') AND (AppliedCurrCode <> _VendLedgEntry."Currency Code"):
                    IF AppliedAmountLCY > ABS(_VendLedgEntry."Remaining Amt. (LCY)") THEN
                        ERROR(Text037, _CurrencyCode, ABS(_VendLedgEntry."Remaining Amt. (LCY)"));
            END;
        END;
    end;

