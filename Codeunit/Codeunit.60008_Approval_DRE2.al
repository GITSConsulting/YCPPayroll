    end;

    procedure InsertEmployeeBuffer(xEmployeeNo: Code[10]; xTableNo: Integer; AdvanceHeaderInsert: Record 50000; PurchaseHeaderInsert: Record 38);
    var
        Employee: Record 5200;
        TipeDokumen: Integer;
        NomorDokumen: Code[20];
        EmployeeNoCreator: Code[20];
        EmployeeHonorary: Record 5200;
    begin
        //#ABM009
        CLEAR(Employee);

        CASE xTableNo OF
            0:
                BEGIN
                    CASE AdvanceHeaderInsert."Document Type" OF
                        AdvanceHeaderInsert."Document Type"::"Travel Advance":
