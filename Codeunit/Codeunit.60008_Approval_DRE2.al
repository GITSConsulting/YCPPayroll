        END;

        IF xEmployeeNo <> '' THEN BEGIN
            Employee.GET(xEmployeeNo);
            Employee.CALCFIELDS("User ID");

            //Insert to employee temp
            IF (NOT EmployeeTemp.GET(Employee."User ID")) AND (Employee."User ID" <> '') AND
               (xEmployeeNo <> EmployeeNoCreator) THEN BEGIN
                EmployeeTemp.INIT;
                EmployeeTemp.Code := Employee."User ID";
                EmployeeTemp.Name := Employee."E-Mail";
                EmployeeTemp.Indentation := xTableNo;
                EmployeeTemp.INSERT;
            END;
        END;
    end;


