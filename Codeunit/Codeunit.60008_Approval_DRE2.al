    procedure ValidateTaxID(var TaxID: Text);
    var
        Decimal: Decimal;
        "Integer": Integer;
        FormatTaxID: Text;
        ValidFormat: Boolean;
    begin
        IF TaxID = '' THEN BEGIN
            TaxID := '00.000.000.0-000.000';
            EXIT;
        END;

        ValidFormat := (COPYSTR(TaxID, 3, 1) = '.') AND (EVALUATE(Integer, COPYSTR(TaxID, 1, 2))) AND
                       (COPYSTR(TaxID, 7, 1) = '.') AND (EVALUATE(Integer, COPYSTR(TaxID, 4, 3))) AND
                       (COPYSTR(TaxID, 11, 1) = '.') AND (EVALUATE(Integer, COPYSTR(TaxID, 8, 3))) AND
                       (COPYSTR(TaxID, 13, 1) = '-') AND (EVALUATE(Integer, COPYSTR(TaxID, 12, 1))) AND
                       (COPYSTR(TaxID, 17, 1) = '.') AND (EVALUATE(Integer, COPYSTR(TaxID, 18, 3))) AND
                       (STRLEN(COPYSTR(TaxID, 18, 3)) = 3);

        IF ValidFormat THEN
            EXIT;

        IF STRLEN(TaxID) <> 15 THEN
            ERROR(Text031, STRLEN(TaxID));

        IF NOT EVALUATE(Decimal, TaxID) THEN
            ERROR(Text030);

        IF STRPOS(TaxID, '.') > 0 THEN
            ERROR(Text030);

        IF STRPOS(TaxID, '-') > 0 THEN
            ERROR(Text030);

        FormatTaxID := INSSTR(TaxID, '.', 3);
        FormatTaxID := INSSTR(FormatTaxID, '.', 7);
        FormatTaxID := INSSTR(FormatTaxID, '.', 11);
        FormatTaxID := INSSTR(FormatTaxID, '-', 13);
        FormatTaxID := INSSTR(FormatTaxID, '.', 17);

        TaxID := FormatTaxID;
        //00.000.000.0-000.000
    end;

