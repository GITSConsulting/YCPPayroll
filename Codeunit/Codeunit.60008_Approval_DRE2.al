    procedure CheckLine(var AdvanceHeader: Record 50000);
    var
        _AdvLine: Record 50001;
        _AdvLine2: Record 50001;
        _BudgetMgt: Codeunit 50003;
        _NewAmount: Decimal;
        _Employee: Record 5200;
        _GenJnlLine: Record 81;
        _PostAdvanceHead: record "New Post Advance Header";
        _AppProfSetup: Record "Approval Chain Setup";
        _RequestAmount: Decimal;
        _BankAcc: Record 270;
        _PostedAdvHeader: record "New Post Advance Header";
        _CurrCodeBuffer: Record 367 temporary;
        _AdvanceLine: Record 50001;
        _EmpLedgerEntry: Record "Employee Ledger Entry";
        _EmpLedgerEntry2: Record "Employee Ledger Entry";
        _EmpLedgerEntry3: Record "Employee Ledger Entry";
        _PostedAdvLine: record "New Post Advance Line";
        _CurrCodeBuffer2: Record 367 temporary;
        _CurrCode: Code[10];
        AttDirectory_: Record "Advance Attachment Entry";
        _BalanceLCY: Decimal;
    begin
        GLSetup.GET;
        AdvanceHeader.CALCFIELDS("Amount (LCY)", "Actual Amount (LCY)", "Journal Amount (LCY) 1");
        IF AdvanceHeader."Document Type" IN [AdvanceHeader."Document Type"::"Settlement Travel Advance", AdvanceHeader."Document Type"::"Settlement General Advance", AdvanceHeader."Document Type"::"Settlement Project Advance"] THEN BEGIN
            AdvanceHeader.TESTFIELD("Ref. Document No.");
            _CurrCodeBuffer.DELETEALL;
            _AdvanceLine.RESET;
            _AdvanceLine.SETRANGE("Document Type", AdvanceHeader."Document Type");
            _AdvanceLine.SETRANGE("Document No.", AdvanceHeader."No.");
            //_AdvanceLine.SETFILTER("Actual Amount",'<>0');
            IF _AdvanceLine.FINDFIRST THEN BEGIN
                REPEAT
                    IF NOT _CurrCodeBuffer.GET(_AdvanceLine."Currency Code") THEN BEGIN
                        _CurrCodeBuffer.INIT;
                        _CurrCodeBuffer.Code := _AdvanceLine."Currency Code";
                        _CurrCodeBuffer."Line Amount" := _AdvanceLine."Actual Amount";
                        _CurrCodeBuffer."Line Amount (LCY)" := _AdvanceLine."Actual Amount (LCY)";
                        _CurrCodeBuffer.INSERT;
                    END ELSE BEGIN
                        _CurrCodeBuffer."Line Amount" += _AdvanceLine."Actual Amount";
                        _CurrCodeBuffer."Line Amount (LCY)" += _AdvanceLine."Actual Amount (LCY)";
                        _CurrCodeBuffer.MODIFY;
                    END;
                UNTIL _AdvanceLine.NEXT = 0;

                _CurrCodeBuffer.FINDFIRST;
                REPEAT
                    IF _CurrCodeBuffer.Code <> '' THEN
                        _CurrCode := _CurrCodeBuffer.Code
                    ELSE
                        _CurrCode := 'IDR';
                    _EmpLedgerEntry2.RESET;
                    _EmpLedgerEntry2.SETRANGE("Integration Doc. Type", AdvanceHeader."Ref. Document Type");
                    _EmpLedgerEntry2.SETRANGE("Original Document No.", AdvanceHeader."Ref. Document No.");
                    _EmpLedgerEntry2.SETRANGE("Employee No.", AdvanceHeader."Employee No.");
                    _EmpLedgerEntry2.SETRANGE(Open, TRUE);

                    _EmpLedgerEntry.RESET;
                    _EmpLedgerEntry.SETRANGE("Integration Doc. Type", AdvanceHeader."Ref. Document Type");
                    _EmpLedgerEntry.SETRANGE("Original Document No.", AdvanceHeader."Ref. Document No.");
                    _EmpLedgerEntry.SETRANGE("Employee No.", AdvanceHeader."Employee No.");
                    _EmpLedgerEntry.SETRANGE("Currency Code (FCY)", _CurrCodeBuffer.Code);
                    _EmpLedgerEntry.SETRANGE(Open, TRUE);
                    IF _EmpLedgerEntry.FINDFIRST THEN
                        _EmpLedgerEntry.CALCFIELDS("Remaining Amount")
                    else begin
                        _EmpLedgerEntry.SETRANGE("Original Document No.");
                        _EmpLedgerEntry.SETRANGE("Document No.", AdvanceHeader."Ref. Document No.");
                        IF _EmpLedgerEntry.FINDFIRST THEN
                            _EmpLedgerEntry.CALCFIELDS("Remaining Amount")
                        else
                            ERROR(Text028, _CurrCode);
                    end;
                    IF (AdvanceHeader."Partial Report") AND (_CurrCodeBuffer."Line Amount" >= _EmpLedgerEntry."Remaining Amount") AND (_EmpLedgerEntry2.COUNT = 1) THEN
                        ERROR(Text026);

                //IF _CurrCodeBuffer.Code = '' THEN
                //_RequestAmount += _EmpLedgerEntry."Remaining Amount (LCY)" - _CurrCodeBuffer."Line Amount (LCY)";
                UNTIL _CurrCodeBuffer.NEXT = 0;

                _PostedAdvLine.SETRANGE("Document Type", AdvanceHeader."Ref. Document Type");
                _PostedAdvLine.SETRANGE("Document No.", AdvanceHeader."Ref. Document No.");
                IF _PostedAdvLine.FINDFIRST THEN BEGIN
                    REPEAT
                        IF NOT _CurrCodeBuffer2.GET(_PostedAdvLine."Currency Code") THEN BEGIN
                            _CurrCodeBuffer2.INIT;
                            _CurrCodeBuffer2.Code := _PostedAdvLine."Currency Code";
                            _CurrCodeBuffer2.INSERT;
                        END;
                    UNTIL _PostedAdvLine.NEXT = 0;

                    IF NOT AdvanceHeader."Partial Report" THEN BEGIN
                        _CurrCodeBuffer2.FINDFIRST;
                        REPEAT
                            _EmpLedgerEntry.RESET;
                            _EmpLedgerEntry.SETRANGE("Integration Doc. Type", AdvanceHeader."Ref. Document Type");
                            _EmpLedgerEntry.SETRANGE("Original Document No.", AdvanceHeader."Ref. Document No.");
                            _EmpLedgerEntry.SETRANGE("Employee No.", AdvanceHeader."Employee No.");
                            _EmpLedgerEntry.SETRANGE("Currency Code (FCY)", _CurrCodeBuffer2.Code);
                            _EmpLedgerEntry.SETRANGE(Open, TRUE);
                            IF (_EmpLedgerEntry.FINDFIRST) AND (NOT _CurrCodeBuffer.GET(_CurrCodeBuffer2.Code)) THEN
                                ERROR(Text027);
                        UNTIL _CurrCodeBuffer2.NEXT = 0;
                    END;
                END;
            END ELSE
                AdvanceHeader.TESTFIELD("Partial Report", FALSE);
        END;

        AdvanceHeader.TESTFIELD("Employee No.");
        _Employee.GET(AdvanceHeader."Employee No.");
        _Employee.SetRange("Document Type Filter", AdvanceHeader."Document Type");
        _Employee.SetFilter("Document No. Filter", '<>%1', AdvanceHeader."No.");
        _Employee.CALCFIELDS("Travel Advance (LCY)", "Project Advance (LCY)", "General Advance (LCY)", "Balance on Request");
        case AdvanceHeader."Document Type" of
            AdvanceHeader."Document Type"::"Travel Advance":
                begin
                    if not AdvanceHeader."Emergency Advance" then
                        if (_Employee."Travel Advance (LCY)" > 0) and (GLSetup."Enable Advance Locking") then
                            Error(Text003);
                    if _Employee."Balance on Request" > 0 then
                        Error(Text004);
                end;

            AdvanceHeader."Document Type"::"Project Advance":
                begin
                    if not AdvanceHeader."Emergency Advance" then
                        if (_Employee."Project Advance (LCY)" > 0) and (GLSetup."Enable Advance Locking") then
                            Error(Text003);
                    if _Employee."Balance on Request" > 0 then
                        Error(Text004);
                end;
            AdvanceHeader."Document Type"::"General Advance":
                begin
                    if not AdvanceHeader."Emergency Advance" then
                        if (_Employee."General Advance (LCY)" > 0) and (GLSetup."Enable Advance Locking") then
                            Error(Text003);
                    if _Employee."Balance on Request" > 0 then
                        Error(Text004);
                end;
        end;

        // _Employee.TESTFIELD("Supervisor ID");
        AdvanceHeader.TESTFIELD("Posting Date");
        _BudgetMgt.ClearBudgetBuffer;
        IF not (AdvanceHeader."Document Type" in [AdvanceHeader."Document Type"::"General Payment",
            AdvanceHeader."Document Type"::"General Cash Receipt"]) THEN BEGIN
            _AdvLine.SETRANGE("Document Type", AdvanceHeader."Document Type");
            _AdvLine.SETRANGE("Document No.", AdvanceHeader."No.");
            _AdvLine.SETRANGE("Bank Entry", FALSE);
            _AdvLine.FINDFIRST;
            REPEAT
                _AdvLine.TESTFIELD("Shortcut Dimension 1 Code");
                _AdvLine.TESTFIELD("Shortcut Dimension 2 Code");
                CASE _AdvLine."Document Type" OF
                    _AdvLine."Document Type"::"Travel Advance", _AdvLine."Document Type"::"Project Advance", _AdvLine."Document Type"::"General Advance":
                        BEGIN
                            IF AdvanceHeader."International Travel" THEN BEGIN
                                AdvanceHeader.TESTFIELD(Justification);
                                AttDirectory_.SETRANGE("Document Type", _AdvLine."Document Type");
                                AttDirectory_.SETRANGE("Document No.", _AdvLine."Document No.");
                                IF NOT AttDirectory_.FINDFIRST THEN
                                    ERROR(Text029);
                            END;
                            AdvanceHeader.TESTFIELD("Purpose of Travel");
                            AdvanceHeader.TESTFIELD("Starting Date");
                            AdvanceHeader.TESTFIELD("Ending Date");
                            _AdvLine.TESTFIELD("Account No.");

                            IF AdvanceHeader."Starting Date" > AdvanceHeader."Ending Date" THEN
                                ERROR(Text010);
                            // IF (AdvanceHeader."Ending Date" - AdvanceHeader."Starting Date") > 50 THEN
                            //     ERROR(Text032);

                            IF AdvanceHeader."Amount (LCY)" = 0 THEN
                                ERROR(Text009, AdvanceHeader."Document Type", AdvanceHeader."No.");
                            IF _AdvLine."Ticket Entry" THEN BEGIN
                                IF _AdvLine."Ticket Type" = _AdvLine."Ticket Type"::Itinerary THEN BEGIN
                                    _AdvLine.TESTFIELD("Account No.");
                                    _AdvLine.TestField(Description);
                                    _AdvLine.TESTFIELD("Passenger Name");
                                    _AdvLine.TESTFIELD("Travel Type");
                                    _AdvLine.TESTFIELD(Starting);
                                    //_AdvLine.TESTFIELD(From);
                                    _AdvLine.TESTFIELD(Destination);
                                    _AdvLine.TESTFIELD("Departure Time");
                                    IF _AdvLine."Travel Type" = _AdvLine."Travel Type"::"Return Trip" THEN BEGIN
                                        _AdvLine.TESTFIELD(Ending);
                                        _AdvLine.TESTFIELD("Return Time");
                                    END ELSE
                                        _AdvLine.TESTFIELD("Return Time", 0T);
                                END ELSE BEGIN
                                    _AdvLine.TESTFIELD("Account No.");
                                    _AdvLine.TestField(Description);
                                    _AdvLine.TESTFIELD("Passenger Name");
                                    _AdvLine.TestField("Expense Type");
                                    _AdvLine.TESTFIELD(Destination);
                                    if _AdvLine."Expense Type" = _AdvLine."Expense Type"::"Hotel Reservation" then begin
                                        _AdvLine.TestField(Starting);
                                        _AdvLine.TestField(Ending);
                                    end;
                                END;
                            END ELSE BEGIN
                                _AdvLine.TESTFIELD("Account No.");
                                _AdvLine.TESTFIELD(Description);
                                _AdvLine.TESTFIELD(Amount);
                                TestGLAcc(_AdvLine."Account No.");
                                _NewAmount := _AdvLine."Amount (LCY)";
                            END;
                        END;

                    _AdvLine."Document Type"::"Petty Cash Replenishment":
                        BEGIN
                            _AdvLine.TESTFIELD("Account No.");
                            _AdvLine.TESTFIELD(Description);
                            _AdvLine.TESTFIELD(Amount);
                            TestGLAcc(_AdvLine."Account No.");
                            _NewAmount := _AdvLine."Amount (LCY)";
                        END;
                    _AdvLine."Document Type"::"Settlement Travel Advance", _AdvLine."Document Type"::"Settlement General Advance", _AdvLine."Document Type"::"Settlement Project Advance":
                        BEGIN
                            //AdvanceHeader.CALCFIELDS(Amount);
                            //IF AdvanceHeader.Amount = 0 THEN
                            //ERROR(Text002,AdvanceHeader."No.");
                            if AdvanceHeader.GetBalanceDueLCY() > 0 then
                                AdvanceHeader.TestField("Bank Transfer Receipt Date")
                            else
                                AdvanceHeader.TestField("Bank Transfer Receipt Date", 0D);
                            CheckAppliedAmountAccPayable(_AdvLine."Applies-to Doc. No.", _AdvLine."Currency Code", _AdvLine."Actual Amount", _AdvLine."Actual Amount (LCY)");

                            _AdvLine.TESTFIELD(Description);
                            IF _AdvLine."Actual Amount" <> 0 THEN
                                _AdvLine.TESTFIELD("Account No.");

                            IF _AdvLine."Actual Amount (LCY)" > _AdvLine."Amount (LCY)" THEN
                                _NewAmount := _AdvLine."Actual Amount (LCY)" - _AdvLine."Amount (LCY)"
                            ELSE
                                _NewAmount := _AdvLine."Actual Amount (LCY)";
                        END;
                    _AdvLine."Document Type"::Reimbursement:
                        BEGIN
                            //WWF2-013
                            //_Employee.GET(AdvanceHeader."Employee No.");
                            //_Employee.CALCFIELDS("Balance (LCY)");
                            //IF _Employee."Person Responsible ID" = '' THEN
                            //IF _Employee."Balance (LCY)" > 0 THEN
                            //ERROR(Text003);

                            CheckAppliedAmountAccPayable(_AdvLine."Applies-to Doc. No.", _AdvLine."Currency Code", _AdvLine.Amount, _AdvLine."Amount (LCY)");
                            _AdvLine.TESTFIELD("Account No.");
                            _AdvLine.TESTFIELD(Description);
                            _AdvLine.TESTFIELD(Amount);
                            // _AdvLine.TESTFIELD("Shortcut Dimension 6 Code");
                            TestGLAcc(_AdvLine."Account No.");
                            _NewAmount := _AdvLine."Amount (LCY)";
                        END;

                    _AdvLine."Document Type"::"Personal Loan":
                        BEGIN
                            _AdvLine.TESTFIELD(Description);
                            _AdvLine.TESTFIELD(Amount);
                        END;
                END;
                _BudgetMgt.InsertBudgetSummary(_AdvLine."Shortcut Dimension 1 Code", _AdvLine."Shortcut Dimension 2 Code",
                                               _AdvLine."Posting Date", _NewAmount, AdvanceHeader."Ref. Document No.");
            //MESSAGE('%1, %2',_AdvLine."Shortcut Dimension 1 Code",_AdvLine."Shortcut Dimension 2 Code");
            UNTIL _AdvLine.NEXT = 0;
        END ELSE BEGIN
            AdvanceHeader.CALCFIELDS("Journal Amount (LCY) 1");

            _GenJnlLine.SETRANGE("Journal Template Name", AdvanceHeader."Journal Template Name");
            _GenJnlLine.SETRANGE("Journal Batch Name", AdvanceHeader."Journal Batch Name");
            _GenJnlLine.FINDFIRST;
            REPEAT
                if _GenJnlLine."Global Dimension 1 Code" <> '' then begin
                    _GenJnlLine.Validate("Shortcut Dimension 1 Code", _GenJnlLine."Global Dimension 1 Code");
                    _GenJnlLine.Modify();
                end;
                if _GenJnlLine."Global Dimension 2 Code" <> '' then begin
                    _GenJnlLine.Validate("Shortcut Dimension 2 Code", _GenJnlLine."Global Dimension 2 Code");
                    _GenJnlLine.Modify();
                end;
                _GenJnlLine.TESTFIELD("Account No.");
                _GenJnlLine.TESTFIELD(Description);
                _GenJnlLine.TESTFIELD(Amount);
                _GenJnlLine.TESTFIELD("Shortcut Dimension 1 Code");
                _GenJnlLine.TESTFIELD("Shortcut Dimension 2 Code");

                CheckAppliedAmountAccPayable(_GenJnlLine."Applies-to Doc. No.", _GenJnlLine."Currency Code", _GenJnlLine.Amount, _GenJnlLine."Amount (LCY)");

                IF (_GenJnlLine."Account Type" = _GenJnlLine."Account Type"::"G/L Account") AND (_GenJnlLine.Amount > 0) THEN
                    _BudgetMgt.InsertBudgetSummary(_GenJnlLine."Shortcut Dimension 1 Code", _GenJnlLine."Shortcut Dimension 2 Code",
                                                   _GenJnlLine."Posting Date", _GenJnlLine.Amount, '');
            UNTIL _GenJnlLine.NEXT = 0;
        END;

        IF AdvanceHeader."Document Type" <> AdvanceHeader."Document Type"::"Travel Authorization" THEN
            _BudgetMgt.CheckBudgetSummary();
    end;

