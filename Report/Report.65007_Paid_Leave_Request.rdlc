                              <Style />
                            </Paragraph>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>Sick leave – an employee who has been sick for more than 1 (one) day, should submit a doctor’s certificate.</Value>
                                  <Style>
                                    <FontStyle>Italic</FontStyle>
                                    <FontFamily>Calibri</FontFamily>
