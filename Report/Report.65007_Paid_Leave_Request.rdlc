                              <Style />
                            </Paragraph>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>Paternity leave should be supported by employee’s wife maternity hospitalization.</Value>
                                  <Style>
                                    <FontStyle>Italic</FontStyle>
                                    <FontFamily>Calibri</FontFamily>
                                    <FontSize>9pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
