                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Left</TextAlign>
                              </Style>
                            </Paragraph>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>Emergency leave - the reasons shall be reported to Supervisor and HR within 24hrs.</Value>
                                  <Style>
                                    <FontStyle>Italic</FontStyle>
                                    <FontFamily>Calibri</FontFamily>
                                    <FontSize>9pt</FontSize>
