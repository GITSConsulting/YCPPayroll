                              <Style />
                            </Paragraph>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>Saya menyetujui bahwa saya akan menerima pembayaran dari Yayasan CARE Peduli. </Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontSize>8pt</FontSize>
