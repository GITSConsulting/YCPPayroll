                              <Style />
                            </Paragraph>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>I acknowledge that I will receive from Yayasan CARE Peduli a payment of </Value>
                                  <Style>
                                    <FontStyle>Italic</FontStyle>
                                    <FontSize>8pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
